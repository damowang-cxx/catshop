NODE_ENV=production
PORT=3001
APP_URL=https://elowynn.com
API_PREFIX=api
COOKIE_SECRET=REPLACE_WITH_STRONG_COOKIE_SECRET
RATE_LIMIT_MAX=200

JWT_SECRET=REPLACE_WITH_STRONG_JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_STRONG_REFRESH_SECRET
ADMIN_EMAIL=admin@elowynn.com
ADMIN_PASSWORD_HASH=REPLACE_WITH_ARGON2ID_HASH
CUSTOMER_EMAIL=seed-customer@elowynn.com
CUSTOMER_PASSWORD_HASH=REPLACE_WITH_ARGON2ID_HASH
GOOGLE_AUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://elowynn.com/api/auth/google/callback

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/catshop
PRISMA_CONNECT_ON_BOOT=true
REDIS_URL=redis://127.0.0.1:6379
CLICKHOUSE_URL=http://127.0.0.1:8123
MEILISEARCH_URL=http://127.0.0.1:7700

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=catshop-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/avif
